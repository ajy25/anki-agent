# Copy this file to ".env" (same folder) and fill in the blanks:
#     cp .env.example .env
# Lines starting with # are comments/examples — uncomment to use them.


# ─────────────────────────────────────────────────────────────────────────
# 1. AI key  (required)
# ─────────────────────────────────────────────────────────────────────────
# Anki Agent uses Groq for the AI features (assisted search and the tutor).
# Make a free key at https://console.groq.com  ->  "API Keys"  ->  Create.
# Paste it here (it should start with "gsk_"):
GROQ_API_KEY=gsk_your_key_here


# ─────────────────────────────────────────────────────────────────────────
# 2. Your deck  (required)
# ─────────────────────────────────────────────────────────────────────────
# Path to your Anki collection on this computer. Anki Agent reads it directly
# (read-only — it never changes your Anki data). Quit Anki or not, either is fine.
#
# Where to find it — replace "<profile>" with your Anki profile name
# (it's "User 1" unless you renamed it):
#   macOS:    ~/Library/Application Support/Anki2/<profile>/collection.anki2
#   Windows:  %APPDATA%\Anki2\<profile>\collection.anki2
#   Linux:    ~/.local/share/Anki2/<profile>/collection.anki2
DECK_PATH=~/Library/Application Support/Anki2/User 1/collection.anki2

# Which deck to study, exactly as its name appears in Anki's deck list.
# Use :: for subdecks, e.g. "AnKing Step Deck::Review::5. Hematology".
# Leave this blank to include every deck in your collection.
DECK_NAME=AnKing Step Deck


# ─────────────────────────────────────────────────────────────────────────
# 3. Optional tweaks  (fine to leave as-is)
# ─────────────────────────────────────────────────────────────────────────
# Which AI model / provider to use. The defaults work out of the box.
LLM_PROVIDER=groq                 # groq | openai
LLM_MODEL=openai/gpt-oss-120b     # Groq's gpt-oss-120b (default)
LLM_REASONING_EFFORT=low          # low | medium | high (deeper = slower)
# OPENAI_API_KEY=sk-...           # only if you set LLM_PROVIDER=openai

# Web server port (open http://127.0.0.1:<PORT> in your browser).
PORT=5050

# Desktop app only: global hotkey to pop the window open (pynput format).
HOTKEY=<ctrl>+<alt>+<space>
